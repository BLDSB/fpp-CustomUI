# Copy this file to .env and fill in each value before starting the app.
# Never commit .env to source control.

# Base URL for the FPP REST API (no trailing slash)
FPP_BASE_URL=http://localhost/api

# Flask secret key — generated automatically by setup.sh
SECRET_KEY=replace-with-a-strong-random-value

# Bcrypt-hashed admin password — set by setup.sh during install
ADMIN_PASSWORD_HASH=

# Secret token for the /internal/* endpoints called by FPP playlists.
# Generated automatically by setup.sh.
INTERNAL_TOKEN=
